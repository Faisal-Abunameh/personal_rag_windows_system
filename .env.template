# ────────────────────────────────────────────────────────────────────────────
# Local RAG System — Configuration Template
# Copy this file to .env and adjust values as needed.
# ────────────────────────────────────────────────────────────────────────────

# ─── Model Settings ───
LLM_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434
LLM_TEMPERATURE=0.7
LLM_TOP_P=0.9
LLM_MAX_TOKENS=4096
LLM_CONTEXT_WINDOW=8192

# ─── RAG Pipeline ───
TOP_K_CHUNKS=20
CHUNK_SIMILARITY_THRESHOLD=0.1
MAX_CHUNK_SIZE=1000
MIN_CHUNK_SIZE=100
CHUNK_OVERLAP_SENTENCES=1

# ─── Conversation ───
MAX_CONVERSATION_HISTORY=20
ENABLE_CHAT_MEMORY=true

# ─── Cache ───
EMBEDDING_CACHE_SIZE=1024
QUERY_CACHE_SIZE=128
QUERY_CACHE_TTL=3600

# ─── Hardware ───
# Options: auto, cpu, cuda
DEVICE=auto

# ─── Paths ───
# If left empty, will default to Desktop/references
REFERENCES_DIR=
